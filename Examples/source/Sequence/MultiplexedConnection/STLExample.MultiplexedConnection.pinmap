			<RelayPosition relay="DmmPinASite2" position="Open" />
			<RelayPosition relay="DmmPinASite3" position="Closed" />
		</RelayConfiguration>
		<RelayConfiguration name="DisconnectDmmFromPinAOnAllSites">
			<RelayPosition relay="DmmPinASite0" position="Open" />
